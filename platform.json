{
  "name": "nordicnrf54",
  "title": "Nordic nRF54L",
  "description": "The nRF54L Series features Cortex-M33 processors at 128 MHz with RRAM-based non-volatile memory, providing a highly capable platform for Bluetooth Low Energy applications with the S145 SoftDevice.",
  "homepage": "https://www.nordicsemi.com/Products/nRF54L15",
  "license": "Apache-2.0",
  "keywords": [
    "dev-platform",
    "ARM",
    "Cortex-M",
    "Nordic Semiconductor",
    "nRF54L",
    "nRF54L15",
    "bluetooth"
  ],
  "engines": {
    "platformio": "^6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/caveman99/platform-nordicnrf54.git"
  },
  "version": "0.1.0",
  "frameworks": {
    "arduino": {
      "package": "framework-arduinoadafruitnrf54",
      "script": "builder/frameworks/arduino.py"
    }
  },
  "packages": {
    "toolchain-gccarmnoneeabi": {
      "type": "toolchain",
      "owner": "platformio",
      "version": "~1.120301.0"
    },
    "framework-arduinoadafruitnrf54": {
      "type": "framework",
      "optional": true,
      "version": "https://github.com/KR4DIO/nrf54-arduino-core.git"
    },
    "framework-arduinoadafruitnrf54-bootloader": {
      "type": "framework",
      "optional": true,
      "version": "https://github.com/caveman99/nRF54_Bootloader.git#v0.1.0"
    },
    "framework-cmsis": {
      "type": "framework",
      "optional": false,
      "owner": "platformio",
      "version": "~2.50700.0"
    },
    "tool-adafruit-nrfutil": {
      "owner": "platformio",
      "optional": false,
      "version": "~1.503.0"
    },
    "tool-sreccat": {
      "owner": "platformio",
      "version": "~1.164.0"
    },
    "tool-openocd": {
      "type": "uploader",
      "optional": true,
      "owner": "platformio",
      "version": "~3.1200.0"
    },
    "tool-nrfjprog": {
      "type": "uploader",
      "optional": true,
      "owner": "platformio",
      "version": "~1.100000.0"
    },
    "tool-jlink": {
      "type": "uploader",
      "optional": true,
      "owner": "platformio",
      "version": "^1.92000.0"
    }
  }
}
